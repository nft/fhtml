{
  "name": "fhtml",
  "displayName": "fhtml",
  "description": "Language support for fhtml (Fluid HTML) — a whitespace-based markup language that compiles 1:1 to HTML. Syntax highlighting plus, when the fhtml compiler is installed, diagnostics, formatting, outline, go-to-definition and completion via `fhtml lsp`.",
  "version": "0.1.0",
  "publisher": "fhtml",
  "license": "MIT",
  "icon": "icon.png",
  "engines": { "vscode": "^1.82.0" },
  "categories": ["Programming Languages", "Formatters", "Linters"],
  "keywords": [
    "fhtml",
    "html",
    "markup",
    "template",
    "tailwind",
    "language-server",
    "syntax-highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nft/fhtml.git",
    "directory": "editors/vscode"
  },
  "bugs": { "url": "https://github.com/nft/fhtml/issues" },
  "homepage": "https://nft.github.io/fhtml/",
  "qna": false,
  "main": "./extension.js",
  "activationEvents": ["onLanguage:fhtml"],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": ["fhtml.path"],
      "description": "Syntax highlighting works everywhere. The language server (an external fhtml binary) only starts in trusted workspaces, and a workspace-provided fhtml.path is ignored until the workspace is trusted."
    }
  },
  "contributes": {
    "languages": [
      {
        "id": "fhtml",
        "aliases": ["fhtml", "Fluid HTML"],
        "extensions": [".fhtml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fhtml",
        "scopeName": "source.fhtml",
        "path": "./syntaxes/fhtml.tmLanguage.json",
        "embeddedLanguages": { "meta.embedded.block.html": "html" }
      }
    ],
    "configuration": {
      "title": "fhtml",
      "properties": {
        "fhtml.path": {
          "type": "string",
          "default": "",
          "description": "Path to the fhtml binary. Empty means `fhtml` on $PATH."
        }
      }
    }
  },
  "scripts": {
    "test": "./test.sh",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3",
    "ovsx": "^1",
    "vscode-tmgrammar-test": "0.1.3"
  }
}
