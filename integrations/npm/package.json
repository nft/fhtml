{
  "name": "@fhtml/core",
  "version": "0.1.0",
  "description": "The fhtml compiler as WebAssembly — render, compile to JS modules, format, and analyze fhtml anywhere JavaScript runs.",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "default": "./node.js"
    },
    "./fhtml.wasm": "./fhtml.wasm"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "node.js",
    "node.d.ts",
    "fhtml.wasm",
    "README.md"
  ],
  "keywords": [
    "fhtml",
    "html",
    "template",
    "compiler",
    "wasm"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "node -e \"require('fs').accessSync('fhtml.wasm')\""
  }
}
