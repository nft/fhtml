// fhtml.dev home — written in fhtml, built by `fhtml build` (dogfood).
// Build with: ./site/build.sh   (fhtml --min --data + tailwindcss + static copy)
// Shared chrome (head, nav, footer, code cards, highlighter) lives in _inc/layout.fhtml.
//
// `card` and `badge` below are the real components used in the "live result"
// panel of the showcase section — the page renders its own example with the
// layout engine, and the code card shows this exact source.
include _inc/layout

def badge(tone label)
  span shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium {tone} "{label}"

def card(name role)
  . flex items-center gap-4 rounded-2xl border border-slate-200 p-4
    . size-11 shrink-0 rounded-full bg-gradient-to-br from-indigo-500 to-fuchsia-500
    . min-w-0 flex-1
      p truncate font-semibold text-slate-900 "{name}"
      p truncate text-sm text-slate-500 "{role}"
    children

doctype
html(lang=en)
  +page_head(title="fhtml — a component markup language that compiles to HTML" desc="fhtml is a whitespace markup language with components, slots, loops, and includes that compiles 1:1 to HTML — your Tailwind classes copied through byte-for-byte." path="/" repo=repo_url site=site_url)
  body min-h-screen bg-white text-slate-900 antialiased selection:bg-indigo-200
    +topnav(active="home" repo=repo_url)

    main
      // ─── Hero ──────────────────────────────────────────────────────────
      section relative overflow-hidden border-b border-slate-200
        .(aria-hidden=true) pointer-events-none absolute inset-x-0 -top-40 -z-10 flex justify-center opacity-60 blur-3xl > . h-80 w-[42rem] bg-gradient-to-tr from-sky-300 via-indigo-300 to-fuchsia-300
        . mx-auto max-w-4xl px-6 pt-16 pb-16 text-center sm:pt-20
          img(src=static/fhtml.png alt="fhtml — Fluid Hypertext Markup Language" width=1030 height=428 fetchpriority=high) mx-auto w-full max-w-xs mix-blend-multiply
          p mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600 sm:text-xl
            | A component-based markup language that compiles 1:1 to HTML. Real
            |
            span font-semibold text-slate-900 "components, slots, loops, and includes"
            |  — written in whitespace, with your
            |
            span font-semibold text-slate-900 "Tailwind"
            |  classes copied through byte-for-byte. No closing tags, no angle brackets.
          . mx-auto mt-8 flex max-w-md flex-col items-center justify-center gap-3 sm:flex-row
            a(href=docs.html) inline-flex items-center gap-x-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500
              | Read the docs
              svg(viewBox="0 0 16 16" fill=none aria-hidden=true) h-4 w-4 > path(d="M3 8h10M9 4l4 4-4 4" stroke=currentColor stroke-width=1.5 stroke-linecap=round stroke-linejoin=round)
            a(href=install.html) inline-flex items-center gap-x-2 rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 shadow-sm transition hover:bg-slate-50 "Install"

      // ─── Showcase: it's a layout engine ────────────────────────────────
      section mx-auto max-w-5xl px-6 py-20 sm:py-24
        . mx-auto max-w-2xl text-center
          p text-sm font-semibold uppercase tracking-wider text-indigo-600 "Components, not string soup"
          h2 mt-2 text-3xl font-semibold tracking-tight sm:text-4xl "Define once. Compose anywhere."
          p mt-4 text-lg leading-8 text-slate-600
            | Declare a block with
            |
            code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.9em] text-slate-700 "def"
            | , give it parameters and a
            |
            code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.9em] text-slate-700 "children"
            |  slot, then reuse it with
            |
            code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.9em] text-slate-700 "+call"
            | . The panel below is this page rendering that exact code.
        . mt-14 space-y-6
          +code_card(file="team.fhtml" lang="fhtml")
            | def badge(tone label)
            |   span shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium \{tone} "\{label}"
            |
            | def card(name role)
            |   . flex items-center gap-4 rounded-2xl border border-slate-200 p-4
            |     . size-11 shrink-0 rounded-full bg-gradient-to-br from-indigo-500 to-fuchsia-500
            |     . min-w-0 flex-1
            |       p truncate font-semibold text-slate-900 "\{name}"
            |       p truncate text-sm text-slate-500 "\{role}"
            |     children
            |
            | +card(name="Erin Lindford" role="Product Engineer")
            |   +badge(tone="bg-green-100 text-green-700" label="Online")
            | +card(name="Tom Cook" role="Director of Operations")
            |   +badge(tone="bg-slate-100 text-slate-500" label="Away")
          // live rendered output, produced by the defs above
          . overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg
            . flex items-center gap-1.5 border-b border-slate-200 bg-slate-50 px-4 py-3
              span size-2.5 rounded-full bg-red-400
              span size-2.5 rounded-full bg-amber-400
              span size-2.5 rounded-full bg-green-400
              span ml-2 text-xs font-medium text-slate-400 "Rendered output"
            . grid gap-3 p-5 sm:grid-cols-2
              +card(name="Erin Lindford" role="Product Engineer")
                +badge(tone="bg-green-100 text-green-700" label="Online")
              +card(name="Tom Cook" role="Director of Operations")
                +badge(tone="bg-slate-100 text-slate-500" label="Away")
        p mt-6 text-center text-sm text-slate-500
          | Same
          |
          code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "def"
          |  works statically or compiles to a
          |
          code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "(data, ctx) => string"
          |  ES module —
          |
          a(href=docs.html#components) font-medium text-indigo-600 hover:text-indigo-500 "see components →"

      // ─── Same source, clean HTML ───────────────────────────────────────
      section bg-slate-50 py-20 sm:py-24
        . mx-auto max-w-5xl px-6
          . mx-auto max-w-2xl text-center
            h2 text-3xl font-semibold tracking-tight sm:text-4xl "One line per element. Real HTML out."
            p mt-4 text-lg leading-8 text-slate-600 "Indentation nests; bare tokens after the tag are the class list, copied to the output byte-for-byte. Nothing magic happens to your markup."
          . mt-14 space-y-4
            +code_card(file="card.fhtml" lang="fhtml")
              | div flex items-center gap-4 rounded-xl bg-white p-6 shadow-md
              |   img(src=/img/ava.jpg alt="Erin's avatar") size-12 rounded-full
              |   .
              |     p text-lg font-semibold text-gray-900 "Erin Lindford"
              |     p text-gray-500 "Product Engineer"
              |   button ml-auto rounded-full px-4 py-1 text-sm "Message"
            . flex justify-center
              . flex h-9 w-9 items-center justify-center rounded-full bg-indigo-100 text-indigo-600
                svg(viewBox="0 0 24 24" fill=none aria-hidden=true) h-5 w-5 rotate-90 > path(d="M5 12h14M13 6l6 6-6 6" stroke=currentColor stroke-width=2 stroke-linecap=round stroke-linejoin=round)
            +code_card(file="index.html" lang="html")
              | <div class="flex items-center gap-4 rounded-xl bg-white p-6 shadow-md">
              |   <img src="/img/ava.jpg" alt="Erin's avatar" class="size-12 rounded-full">
              |   <div>
              |     <p class="text-lg font-semibold text-gray-900">Erin Lindford</p>
              |     <p class="text-gray-500">Product Engineer</p>
              |   </div>
              |   <button class="ml-auto rounded-full px-4 py-1 text-sm">Message</button>
              | </div>
          p mt-6 text-center text-sm text-slate-500
            | Every token after the tag is a class, verbatim.
            |
            a(href=docs.html) font-medium text-indigo-600 hover:text-indigo-500 "Read the full syntax →"

      // ─── Capability grid ───────────────────────────────────────────────
      section mx-auto max-w-6xl px-6 py-20 sm:py-24
        . mx-auto max-w-2xl text-center
          h2 text-3xl font-semibold tracking-tight sm:text-4xl "A whole toolchain, not a preprocessor"
          p mt-4 text-lg leading-8 text-slate-600 "The language is small; the surface around it is complete."
        . mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3
          a(href=docs.html#components) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "Components & slots"
            p mt-2 text-sm leading-6 text-slate-600
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "def"
              |  blocks with parameters, a
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "children"
              |  slot, and
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "+call"
              |  instantiation.
          a(href=docs.html#interpolation) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "Template layer"
            p mt-2 text-sm leading-6 text-slate-600
              | Interpolation,
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "if"
              | /
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "for"
              | /
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "empty"
              |  over a small closed expression language.
          a(href=docs.html#include) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "Includes"
            p mt-2 text-sm leading-6 text-slate-600 "Split a page across files. Shared defs, one namespace, no import ceremony."
          a(href=docs.html#tooling) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "Tooling"
            p mt-2 text-sm leading-6 text-slate-600
              | A canonical formatter, a reverse
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "html2fhtml"
              |  converter, and a language server.
          a(href=install.html#javascript) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "JavaScript & WASM"
            p mt-2 text-sm leading-6 text-slate-600
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "@fhtml/core"
              |  for Node, browsers, and the edge — with Express and Hono adapters, plus a Vite plugin.
          a(href=docs.html#tailwind) group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md
            h3 font-semibold text-slate-900 "Tailwind-native"
            p mt-2 text-sm leading-6 text-slate-600
              | Classes are plain tokens, so
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 "@source"
              |  scans
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.85em] text-slate-700 ".fhtml"
              |  files directly.

      // ─── The whole language, in 30 seconds ─────────────────────────────
      section bg-slate-900 py-20 text-slate-100 sm:py-24
        . mx-auto max-w-6xl px-6
          . mx-auto max-w-2xl text-center
            h2 text-3xl font-semibold tracking-tight text-white sm:text-4xl "The whole language, in 30 seconds"
            p mt-4 text-lg leading-8 text-slate-300
              | Line shape:
              |
              code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.9em] text-indigo-200 "tag(attrs) #id classes… \"text\""
              |  — everything after the tag is optional.
          . mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Nesting"
              p mt-1.5 text-sm leading-6 text-slate-300 "Indentation nests — Python's rules exactly. No closing tags, ever."
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Classes"
              p mt-1.5 text-sm leading-6 text-slate-300 "Bare tokens after the tag are classes, copied verbatim. The compiler never looks inside one."
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Attributes"
              p mt-1.5 text-sm leading-6 text-slate-300
                | Live in parens, butted against the tag —
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "a(href=/about target=_blank)"
                | .
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Div & id"
              p mt-1.5 text-sm leading-6 text-slate-300
                | A lone
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "."
                |  is a div;
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "#id"
                |  sets the id.
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Text"
              p mt-1.5 text-sm leading-6 text-slate-300
                | Quoted text is HTML-escaped;
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "|"
                |  starts a multi-line text block.
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Inline chains"
              p mt-1.5 text-sm leading-6 text-slate-300
                | One inline child with
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 ">"
                |  —
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "li > a(href=/docs) \"Docs\""
                | .
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Raw HTML"
              p mt-1.5 text-sm leading-6 text-slate-300
                | A line starting with
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "<"
                |  is raw passthrough — the escape hatch.
            . rounded-xl border border-white/10 bg-white/5 p-5
              h3 text-sm font-semibold text-white "Extras"
              p mt-1.5 text-sm leading-6 text-slate-300
                | Trailing
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "\\"
                |  continues a line;
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "//"
                |  comments;
                |
                code rounded bg-white/10 px-1.5 py-0.5 font-mono text-[0.8em] text-indigo-200 "doctype"
                |  for the DOCTYPE.
          p mt-10 text-center text-sm text-slate-400
            a(href=docs.html) font-medium text-indigo-300 hover:text-indigo-200 "See every rule with examples in the docs →"

      // ─── Template layer teaser ─────────────────────────────────────────
      section mx-auto max-w-6xl px-6 py-20 sm:py-24
        . grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center
          . min-w-0
            h2 text-3xl font-semibold tracking-tight sm:text-4xl "Loop and branch over your data"
            p mt-4 text-lg leading-8 text-slate-600
              | Interpolation, conditionals, and loops render against JSON — over a
              | small closed expression language, not arbitrary JavaScript. Render
              | statically with the Rust binary, or compile to a
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.9em] text-slate-700 "(data, ctx) => string"
              |  ES module with
              |
              code rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[0.9em] text-slate-700 "--target=js"
              |  — byte-identical to the Rust renderer.
            p mt-6
              a(href=docs.html#conditionals) inline-flex items-center gap-x-2 text-sm font-semibold text-indigo-600 hover:text-indigo-500
                | Template docs
                svg(viewBox="0 0 16 16" fill=none aria-hidden=true) h-4 w-4 > path(d="M3 8h10M9 4l4 4-4 4" stroke=currentColor stroke-width=1.5 stroke-linecap=round stroke-linejoin=round)
          +code_card(file="users.fhtml" lang="fhtml")
            | def badge(text)
            |   span text-xs text-indigo-400 "\{text}"
            |
            | ul divide-y
            |   for user in users
            |     li flex justify-between py-2
            |       span "\{user.name}"
            |       if user.admin
            |         +badge(text="admin")
            |   empty
            |     li text-slate-500 "No users yet."

      // ─── Numbers ───────────────────────────────────────────────────────
      section bg-slate-50 py-20 sm:py-24
        . mx-auto max-w-5xl px-6
          dl grid grid-cols-1 gap-6 sm:grid-cols-3
            a(href="{repo_url}/blob/main/bench/RESULTS.md") group flex flex-col rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm transition hover:border-indigo-300 hover:shadow-md
              dt order-2 mt-2 text-sm font-medium text-slate-600 "round-trip DOM fidelity"
              dd order-1 bg-gradient-to-br from-indigo-600 to-fuchsia-600 bg-clip-text text-5xl font-bold tracking-tight text-transparent "48/48"
              dd order-3 mt-3 text-xs text-slate-400 "html → fhtml → identical DOM"
            . flex flex-col rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm
              dt order-2 mt-2 text-sm font-medium text-slate-600 "dependencies in the compiler"
              dd order-1 bg-gradient-to-br from-indigo-600 to-fuchsia-600 bg-clip-text text-5xl font-bold tracking-tight text-transparent "0"
              dd order-3 mt-3 text-xs text-slate-400 "one Rust binary · cargo install"
            a(href="{repo_url}/blob/main/bench/RESULTS.md") group flex flex-col rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm transition hover:border-indigo-300 hover:shadow-md
              dt order-2 mt-2 text-sm font-medium text-slate-600 "fewer tokens than pretty HTML"
              dd order-1 bg-gradient-to-br from-indigo-600 to-fuchsia-600 bg-clip-text text-5xl font-bold tracking-tight text-transparent "−14%"
              dd order-3 mt-3 text-xs text-slate-400 "up to −20% on SVG-light markup"
          p mt-8 text-center text-sm text-slate-500
            | Models write it reliably, too: across four LLMs on one corpus, 90.6% of
            | generated fhtml compiled, versus 44.3% for Pug.
            |
            a(href="{repo_url}/blob/main/bench/RESULTS.md#generation-reliability-models-writing-fhtml") font-medium text-indigo-600 hover:text-indigo-500 "Generation benchmark →"

    +foot(repo=repo_url)
    +highlight_script()
    +copy_script()
